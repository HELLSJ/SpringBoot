<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mybatisdemo.mapper.ArticleInfoMapper">

    <select id="selectArticleById" resultType="com.example.mybatisdemo.model.ArticleInfo">
        select * from articleinfo where id = #{id}
    </select>


    <select id="selectArticleAndUserById" resultType="com.example.mybatisdemo.model.ArticleInfo">
        select ta.*, tb.username, tb.gender from articleinfo ta
        left join userinfo tb
        on ta.uid = tb.id
        where ta.id = #{id}
    </select>

</mapper>